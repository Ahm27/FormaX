{
  "name": "pharmacy-sys",
  "private": true,
  "version": "0.0.1",
  "description": "Local pharmacy follow-up system for Dr Sherin Pharmacy.",
  "author": "Ahmed Amr",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "start": "node scripts/start-local-system.mjs",
    "server": "node backend/server.js",
    "serve:static": "node scripts/serve-static.mjs",
    "dedupe:db": "node scripts/remove-db-duplicates.mjs",
    "clean:db": "node scripts/clean-db.mjs",
    "check:delivery": "node scripts/delivery-check.mjs",
    "package:windows-portable": "node scripts/prepare-windows-portable.mjs",
    "electron:icons": "node scripts/generate-electron-icons.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "npm run build && npm run electron:icons && electron .",
    "electron:prepare": "npm run build && npm run electron:icons && electron-builder install-app-deps",
    "electron:dist:mac": "npm run build && npm run electron:icons && electron-builder --mac dir",
    "electron:dist:win": "npm run build && npm run electron:icons && electron-builder --win nsis",
    "electron:dist:portable": "npm run build && npm run electron:icons && electron-builder --win portable",
    "electron:dist:win:dir": "npm run electron:prepare && electron-builder --win dir --x64"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "cors": "^2.8.6",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "express": "^5.2.1",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "^2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "4.1.12",
    "vite": "^6.3.5"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "com.drsherin.pharmacy",
    "productName": "Dr Sherin Pharmacy",
    "directories": {
      "output": "release/electron",
      "buildResources": "build"
    },
    "asar": false,
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "icon.icns"
    },
    "files": [
      "backend/**/*",
      "build/**/*",
      "dist/**/*",
      "docs/**/*",
      "electron/**/*",
      "public/**/*",
      "scripts/**/*",
      "src/**/*",
      "index.html",
      "package.json",
      "package-lock.json",
      "postcss.config.mjs",
      "vite.config.ts"
    ],
    "extraResources": [
      {
        "from": "pharmacy.db",
        "to": "pharmacy.db"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
